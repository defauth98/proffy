{
  "name": "server",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "pnpm exec tsc",
    "migrate": "tsx src/database/migrate.ts",
    "seed": "tsx src/database/seed.ts",
    "rollback": "echo \"Rollback is not supported by the Drizzle SQL runner\" && exit 1",
    "migrate:prod": "node dist/src/database/migrate.js",
    "create:test-user": "node scripts/create-test-user.js",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run tests/unit tests/architecture",
    "test:integration": "vitest run tests/integration/auth-controller.test.ts && vitest run tests/integration/classes-controller.test.ts && vitest run tests/integration/schedule-controller.test.ts && vitest run tests/integration/favorites-controller.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.17.1",
    "jsonwebtoken": "^8.5.1",
    "nodemailer": "^6.4.11",
    "nodemailer-express-handlebars": "^5.0.0",
    "pg": "^8.4.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/cors": "^2.8.7",
    "@types/express": "^4.17.7",
    "@types/express-handlebars": "^6.0.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/node": "^17.0.42",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "ts-node": "^10.8.1",
    "tsx": "^4.22.4",
    "typescript": "^4.7.3",
    "vitest": "^4.1.9"
  }
}
